# RxBridge Environment Variables
# ─────────────────────────────────────────────────────────
# 1. Copy this file:   Copy-Item .env.example .env
# 2. Fill in values below
# 3. NEVER commit .env to Git — it's in .gitignore
# ─────────────────────────────────────────────────────────

# ── Database (Neon PostgreSQL — free tier) ────────────────
# Get from: https://neon.tech → New Project → Connection String
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/rxbridge?sslmode=require

# ── Redis ────────────────────────────────────────────
# Option A: Local Redis (if installed on your machine)
REDIS_URL=redis://localhost:6379
# Option B: Redis with password (if you set one via redis.conf)
# REDIS_URL=redis://:yourpassword@localhost:6379
# Option C: Upstash (cloud, for production or if you don't have local Redis)
# REDIS_URL=rediss://default:your_token@your-db.upstash.io:6379

# ── JWT ───────────────────────────────────────────────────
# Generate:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_STRING_MIN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# ── LLM (Groq — free tier, 500+ tokens/sec) ──────────────
# Get from: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your_groq_key_here

# ── Telegram (optional — for CUSUM alerts) ────────────────
# Create bot: @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=123456:ABCDEFabcdef
TELEGRAM_FAMILY_CHANNEL_ID=@your_channel

# ── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Environment ───────────────────────────────────────────
# "development" enables /docs and disables HSTS
# "production"  disables /docs and enables HSTS
ENVIRONMENT=development
GEMINI_API_KEY=